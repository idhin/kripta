# === Database ===
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://kripta:kripta@localhost:5432/kripta?schema=public"

# === Aplikasi ===
# URL publik aplikasi (dipakai untuk pengecekan origin & pembuatan invite link).
APP_URL="http://localhost:3000"

# Set "true" HANYA saat dijalankan di belakang HTTPS (produksi).
# Saat true, cookie sesi memakai flag Secure.
AUTH_COOKIE_SECURE="false"

# Umur sesi (detik). Default: absolut 30 hari, idle 12 jam.
SESSION_ABSOLUTE_TTL="2592000"
SESSION_IDLE_TTL="43200"
